# ================================================
# نموذج المتغيرات البيئية | Environment Variables
# انسخ هذا الملف باسم .env وعدّل القيم
# Copy this file to .env and update the values
# ================================================

# ─── قاعدة البيانات | Database ────────────────────
POSTGRES_USER=hruser
POSTGRES_PASSWORD=hrpassword
POSTGRES_DB=hr_db

# ─── الجلسة | Session ─────────────────────────────
# غيّر هذه القيمة لسلسلة عشوائية طويلة لا تقل عن 32 محرفاً
# Change this to a long random string of at least 32 characters
SESSION_SECRET=change_this_to_a_long_random_string_minimum_32_chars

# ─── الخادم | Server ──────────────────────────────
APP_PORT=5001
NODE_ENV=production

# ─── الكوكيز | Cookies ────────────────────────────
# true في بيئة HTTPS، false في بيئة HTTP المحلية
# true for HTTPS environments, false for local HTTP
COOKIE_SECURE=false
